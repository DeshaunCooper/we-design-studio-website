# We Design Studio — Environment Variables
# Copy to .env.local for local dev (never commit .env.local)
# Set these in Vercel: Project Settings → Environment Variables

# ── EMAIL (Gmail SMTP via App Password) ──────────────────────────────────────
# Setup: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Create an App Password for "Mail" → copy the 16-char code as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello@wedesignsstudio.com
SMTP_PASS=GOOGLE_APP_PASSWORD_HERE
SMTP_FROM=hello@wedesignsstudio.com
CONTACT_TO_EMAIL=hello@wedesignsstudio.com

# ── ADMIN AUTH ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=hello@wedesignsstudio.com
ADMIN_PASSWORD=CHANGE_THIS_TO_YOUR_PASSWORD
# Generate with: openssl rand -hex 32
ADMIN_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING

# ── STRIPE ────────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_KEY
# Set SITE_URL to your Vercel domain for correct redirect URLs
SITE_URL=https://we-design-studio-website.vercel.app

# Optional — pre-created Stripe Price IDs
# If not set, the API uses price_data (creates prices dynamically)
# STRIPE_PRICE_LANDING_PAGE=price_xxx
# STRIPE_PRICE_FULL_WEBSITE=price_xxx
# STRIPE_PRICE_SWIFT_MVP=price_xxx
